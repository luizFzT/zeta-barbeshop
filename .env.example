VITE_SUPABASE_URL=your_supabase_url_here

# Prefer the new publishable key format (sb_publishable_...) over the legacy JWT anon key.
# Get it from: Supabase Dashboard > Settings > API > Publishable keys
VITE_SUPABASE_ANON_KEY=sb_publishable_your_key_here

# Set to "true" only in local dev to enable demo mode (no Supabase required)
# Never set this to "true" in production
VITE_ALLOW_DEMO_MODE=false
